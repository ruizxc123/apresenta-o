                <thead>
                    <tr>
                        <th>Tipo de Verbo</th>
                        <th>Função Semântica</th>
                        <th>Exemplo</th>
                        <th>Análise</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Intransitivo</strong></td>
                        <td>Descreve uma ação completa</td>
                        <td>"Ela correu rapidamente"</td>
                        <td>O verbo carrega toda a informação; pode existir sozinho</td>
                    </tr>
                    <tr>
                        <td><strong>De Ligação</strong></td>
                        <td>Estabelece relação sujeito-atributo</td>
