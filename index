        function checkQuiz(el, isCorrect, quizNumber) {
            const cards = document.querySelectorAll(`#quiz-area-${quizNumber} .option-card`);
            const feedback = document.getElementById(`quiz-feedback-${quizNumber}`);
            
            cards.forEach(c => c.classList.remove('correct-ans', 'wrong-ans'));
            feedback.style.display = 'none';
            
            if(isCorrect) {
                el.classList.add('correct-ans');
                
                const feedbackTexts = {
                    1: "✓ CORRETO! Na alternativa 'C', o verbo 'permanecia' conecta o sujeito 'réu' ao adjetivo 'impassível', estabelecendo uma relação de estado. Nas demais: (A) 'andavam' é intransitivo (ação), (B) 'permaneceu' é intransitivo (localização), (D) 'viraram' é transitivo (ação física).",
                    2: "✓ CORRETO! A dicotomia ser/estar é fundamental em português. 'Ser cansado' sugere uma característica permanente ou traço de personalidade; 'estar cansado' indica um estado momentâneo e passageiro. Esta é a distinção mais importante da língua portuguesa.",
                    3: "✓ CORRETO! Em 'Ela anda preocupada com os filhos', o verbo 'anda' funciona como ligação, conectando o sujeito ao adjetivo 'preocupada'. Indica um estado habitual ou prolongado. As demais alternativas contêm verbos intransitivos que descrevem ações.",
                    4: "✓ CORRETO! 'Meu avó é um grande engenheiro' contém um predicativo substantivo ('engenheiro'). As demais alternativas têm predicativos adjetivos: 'bonito', 'escura', 'feliz'.",
                    5: "✓ CORRETO! Em 'Ela vive feliz com sua família', 'viver' funciona como verbo de ligação, estabelecendo uma relação entre o sujeito e o estado 'feliz'. Nas demais: (A) é localização, (C) é modo de vida, (D) é profissão/sustento."
                };
                
                feedback.innerHTML = feedbackTexts[quizNumber];
                feedback.style.color = "#16a34a";
                feedback.style.display = 'block';
            } else {
                el.classList.add('wrong-ans');
                feedback.innerHTML = "✗ INCORRETO. Revise a análise desta alternativa. Dica: Verifique se o verbo estabelece uma relação entre sujeito e atributo (ligação) ou descreve uma ação (intransitivo).";
                feedback.style.color = "#dc2626";
                feedback.style.display = 'block';
            }
        }

        // Smooth scroll para links internos
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
</body>

